From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: armbian <armbian@armbian.com>
Date: Wed, 4 Jun 2026 10:00:00 +0800
Subject: arm: dts: sun8i-h3-nanopi-neo: set usb_otg dr_mode to peripheral

Set USB OTG port to peripheral mode for USB gadget support.

---
 arch/arm/boot/dts/allwinner/sun8i-h3-nanopi-neo.dts | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/arch/arm/boot/dts/allwinner/sun8i-h3-nanopi-neo.dts b/arch/arm/boot/dts/allwinner/sun8i-h3-nanopi-neo.dts
index 111111111111..222222222222 100644
--- a/arch/arm/boot/dts/allwinner/sun8i-h3-nanopi-neo.dts
+++ b/arch/arm/boot/dts/allwinner/sun8i-h3-nanopi-neo.dts
@@ -74,3 +74,8 @@ &ehci0 {
 &ohci0 {
        status = "okay";
 };
+
+&usb_otg {
+       dr_mode = "peripheral";
+       status = "okay";
+};
-- 
Armbian
